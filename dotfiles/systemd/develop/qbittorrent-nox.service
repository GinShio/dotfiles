[Unit]
Description=qBittorrent-nox Command Line Client
Documentation=man:qbittorrent-nox(1)
After=network.target

[Service]
Type=simple
# Start qbittorrent-nox
ExecStart={{@@ host_app_qbittorrent_bin @@}}
# Gracefully stop the process
ExecStop={{@@ host_app_kill_bin @@}} -w -s TERM $MAINPID
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
