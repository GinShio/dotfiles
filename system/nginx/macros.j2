{%@@ macro proxy_pass(bind, port) @@%}
        location / {
            proxy_pass          http://{{@@ bind @@}}:{{@@ port @@}};
            proxy_http_version  1.1;
            proxy_redirect      off;
            proxy_set_header    Host                 $http_host;
            proxy_set_header    X-Real-IP            $remote_addr;
            proxy_set_header    X-Forwarded-For      $proxy_add_x_forwarded_for;
            proxy_set_header    X-Forwarded-Proto    $scheme;
        }
{%@@ endmacro @@%}

{%@@ macro static_site(root_dir, index_file='index.html') @@%}
        charset               utf-8;
        root                  {{@@ root_dir @@}};
        index                 {{@@ index_file @@}};
        error_page            404    /404.html;

        location ~* \.html$ {
            expires -1;
            add_header Cache-Control "no-cache" always;
            try_files $uri =404;
        }

        location ~* \.(css|js|mjs|map|png|jpg|jpeg|gif|webp|ico|svg|woff2?|ttf|eot)$ {
            expires 30d;
            add_header Cache-Control "public, max-age=2592000, immutable";
            try_files $uri =404;
        }

        location ^~ /.well-known/ {
            allow all;
            try_files $uri =404;
        }

        location ~ /\.(?!well-known/) {
            deny all;
        }

        location = /robots.txt {
            access_log off;
            expires 1d;
            add_header Cache-Control "public, max-age=86400";
            try_files $uri =404;
        }

        location = /404.html {
            internal;
        }

        location / {
            try_files $uri $uri/ =404;
        }
{%@@ endmacro @@%}

{%@@ macro ssl_config(subdomain, base_domain) @@%}
        ssl_certificate       /etc/letsencrypt/live/{{@@ base_domain @@}}/fullchain.pem;
        ssl_certificate_key   /etc/letsencrypt/live/{{@@ base_domain @@}}/privkey.pem;
        ssl_protocols         TLSv1.2 TLSv1.3;
        ssl_ciphers           TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256:TLS_AES_128_GCM_SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-RSA-CHACHA20-POLY1305:ECDHE:ECDH:RSA:AES:+HIGH:+EXP:!aNULL:!eNULL:!NULL:!EXPORT:!DES:!MD5:!DH:!ADH:!DHE:!EDH:!kEDH:!PSK:!RC4;
        ssl_session_cache     shared:{{@@ subdomain | replace('.', '_') @@}}_http:32m;
        ssl_session_timeout   30m;
{%@@ endmacro @@%}

{%@@ macro common_headers() @@%}
        add_header            Strict-Transport-Security    "max-age=15768000; includeSubDomains" always;
        add_header            X-Content-Type-Options       "nosniff" always;
        add_header            Referrer-Policy              "strict-origin-when-cross-origin" always;
{%@@ endmacro @@%}

{%@@ macro server_block_base(subdomain, base_domain) @@%}
server {
        listen         80;
        server_name    {{@@ subdomain @@}};
        return 301     https://$http_host$request_uri;
}

server {
        listen                443 ssl http2;
        listen                [::]:443 ssl http2;
        server_name           {{@@ subdomain @@}};

{{@@ ssl_config(subdomain, base_domain) @@}}

        access_log            off;
        error_log             off;
        client_max_body_size  2m;
        keepalive_timeout     90s;
        gzip                  on;
        gzip_types            text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript image/svg+xml;

{{@@ common_headers() @@}}

        # --- Custom Configuration Start ---
        {{@@ caller() @@}}
        # --- Custom Configuration End ---
}
{%@@ endmacro @@%}
